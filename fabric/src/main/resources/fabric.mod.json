    "client": ["com.sxilverr.lootall.fabric.LootAllFabricClient"],
    "modmenu": ["com.sxilverr.lootall.fabric.ModMenuIntegration"]
  },
  "mixins": ["lootall.mixins.json"],
  "depends": {
    "fabricloader": ">=0.15.0",
