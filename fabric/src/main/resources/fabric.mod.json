{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Looting made easy.",
  "authors": ["Sxilverr"],
  "contact": {
    "issues": "https://www.curseforge.com/minecraft/mc-mods/loot-all"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
